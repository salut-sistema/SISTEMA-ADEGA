# ============================================================
# .env — Variáveis de ambiente do backend
# ⚠️ NUNCA envie este arquivo para o GitHub (já está no .gitignore)
# ============================================================

# ── MONGODB ──────────────────────────────────────────────────
# Conexão com o MongoDB Atlas (já configurada e funcionando)
# Não altere a menos que mude de banco de dados
MONGODB_URI=mongodb+srv://salutsistema:salutsistema@sistema.y8rw92i.mongodb.net/?appName=sistema

# ── PORTA ────────────────────────────────────────────────────
# Em produção o Render define a porta automaticamente via variável PORT
# Não precisa alterar este valor
PORT=3001

# ── CORS — URL DO FRONTEND ────────────────────────────────────
# 🚀 PASSO 2 — DEPLOY: ALTERE AQUI APÓS PUBLICAR O FRONTEND NA VERCEL
#
# Em desenvolvimento: deixe como * (aceita qualquer origem)
# Em produção: coloque a URL exata da Vercel
#
# Como obter a URL da Vercel:
#   1. Acesse https://vercel.com e faça login
#   2. Clique no seu projeto frontend
#   3. Copie a URL (ex: https://minha-adega.vercel.app)
#   4. Cole aqui substituindo o * abaixo
#
# Exemplo em produção:
#   FRONTEND_URL=https://minha-adega.vercel.app
#
# Se tiver mais de uma URL (domínio personalizado + vercel), separe por vírgula:
#   FRONTEND_URL=https://minha-adega.vercel.app,https://www.minhaadega.com.br
# ============================================================
FRONTEND_URL=*
